# 로컬 실행 시 .env 파일로 복사 후 사용
# cp .env.example .env

# ── Core ─────────────────────────────────────────────
DATABASE_URL=postgresql://glowtrip:glowtrip@localhost:5433/glowtrip
SECRET_KEY=change-me-in-production

# ── JWT ──────────────────────────────────────────────
# JWT_SECRET=            # 미설정 시 SECRET_KEY 사용
# JWT_ACCESS_EXPIRES=3600        # Access 토큰 만료 (초, 기본 1시간)
# JWT_REFRESH_EXPIRES=604800     # Refresh 토큰 만료 (초, 기본 7일)

# ── AI 번역 (PydanticAI + Gemini Flash) ──────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── 결제 (Stripe) ────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
# PLATFORM_FEE_RATE=0.1         # 플랫폼 수수료율 (기본 10%)

# ── 지도 (Google Maps) ──────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── 이메일 (SendGrid) ───────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@glowtrip.com
# SENDGRID_FROM_NAME=Glow Trip

# ── 푸시 알림 (FCM) ─────────────────────────────────
# FCM_SERVER_KEY=your-fcm-server-key-here
# NOTIFICATION_REMINDER_HOURS=24

# ── 소셜 로그인 ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.yourcompany.glowtrip
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
